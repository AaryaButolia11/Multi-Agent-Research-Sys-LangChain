# ═══════════════════════════════════════════════════════════════════════════
# ResearchMind .gitignore
# Comprehensive exclusions for Python, Streamlit, and development workflows
# ═══════════════════════════════════════════════════════════════════════════

# ─── Python ──────────────────────────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# ─── Streamlit ───────────────────────────────────────────────────────────────
# Streamlit cache
.streamlit/cache/
.streamlit/logger/
.streamlit/secrets.toml

# Streamlit config
.streamlit/config.toml

# ─── IDE & Editors ───────────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace
.history/
.vscode-remote/

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr
*.range
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
.vim/
*~
*.swp
*.swo
*~.nib
.*.sw[p|n]

# Emacs
*~
\#*\#
.\#*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# ─── Project-Specific ────────────────────────────────────────────────────────
# API keys and secrets
.env.local
.env.*.local
secrets.json
credentials.json
api_keys.txt
.secrets/

# LangChain cache
.langchain_cache/
langchain_db/

# Generated reports
reports/
*.md.bak
*.backup

# Data directories
data/
raw_data/
processed_data/
outputs/
temp/
tmp/
*.csv
*.xlsx
*.json

# Research outputs
research_reports/
*.pdf
*.docx

# Logs
logs/
*.log

# Research agent outputs
agent_outputs/
search_results/
scraped_content/

# ─── Development & Testing ───────────────────────────────────────────────────
# Test data
test_data/
test_outputs/
fixtures/

# Performance profiling
*.prof
prof_output/

# ─── Package managers ────────────────────────────────────────────────────────
# Poetry
poetry.lock

# Conda
conda-lock.yml

# pip-compile
requirements.txt.in
requirements-dev.txt.in

# ─── Docker ──────────────────────────────────────────────────────────────────
# Docker
.dockerignore
docker-compose.override.yml
.docker/

# ─── CI/CD ───────────────────────────────────────────────────────────────────
# GitHub Actions
.github/workflows/local/

# GitLab CI
.gitlab-ci.local.yml

# Jenkins
Jenkinsfile.local

# ─── OS Temporary Files ──────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.bak.*
*.old

# ─── Python Package Files ───────────────────────────────────────────────────
# setuptools
setup.py.bak
setup.cfg.bak

# ─── Research & Documentation ───────────────────────────────────────────────
# Draft files
*.draft
*.wip
TODO.md
NOTES.md
SCRATCH.md

# Temporary documentation
docs/drafts/
docs/temp/

# ─── Node.js (if using any JS tools) ─────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# ─── Database files ──────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
.db/

# ─── Misc ────────────────────────────────────────────────────────────────────
# OS-generated files
.DS_Store
Thumbs.db

# Backup files created by editors
*.bak
*.sav
*.tmp

# Pydantic
.pydantic/

# ─── EXCEPT (Explicitly Include) ──────────────────────────────────────────────
# Keep these important files even if they match above patterns
!.gitkeep
!.env.example
!.env.template
!examples/
!docs/
!tests/
!.github/